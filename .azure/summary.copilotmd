## Azure Resource Architecture

```mermaid
graph TD
  subgraph "Source"
    src["`ReadingTimeDemo
    .NET 10 ASP.NET Core MVC
    src/ReadingTimeDemo/Dockerfile`"]
  end

  subgraph "Container Registry"
    acr["`Azure Container Registry
    azcr{token}`"]
  end

  subgraph "Identity"
    mi["`User-Assigned Managed Identity
    azmi{token}`"]
  end

  subgraph "Compute"
    env["`Container Apps Environment
    azce{token}`"]
    ca["`Azure Container App
    azca{token}
    Port: 8080`"]
  end

  subgraph "Dependencies"
    appconfig["`Azure App Configuration
    azac{token}`"]
    storage["`Azure Storage Account
    azst{token}
    container: static-assets`"]
    kv["`Azure Key Vault
    azkv{token}`"]
    ai["`Application Insights
    azai{token}`"]
    law["`Log Analytics Workspace
    azlaw{token}`"]
  end

  src -->|"az acr build"| acr
  acr -->|"AcrPull (MI)"| ca
  ca -->|"hosted in"| env
  env -->|"logs to"| law
  ai -->|"backed by"| law
  mi -->|"Data Reader"| appconfig
  mi -->|"Blob Contributor"| storage
  mi -->|"Secrets Officer"| kv
  kv -->|"stores"| ai
  ca -.->|"system-identity via MI"| appconfig
  ca -.->|"system-identity via MI"| storage
  ca -.->|"secret ref"| kv
  ca -.->|"telemetry"| ai
```

